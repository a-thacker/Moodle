# Copy to .env (gitignored) and fill in. The sync agent reads this file;
# real environment variables take precedence. All values optional — the
# agent runs fully local without them.

# Supabase project (Settings → API). The service-role key bypasses RLS and
# must only ever exist on this machine — never in hub/ code or Netlify.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ntfy push notifications. On the public ntfy.sh the topic name IS the
# password: use a long random string, e.g. `openssl rand -hex 16`, and
# subscribe to it in the ntfy phone app.
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh   # uncomment when self-hosting ntfy (Phase 2)
