# Copy to command-center/.env and fill in. Consumed by docker-compose and,
# through it, the backend. Never commit the real .env (it holds the DB
# password). Compose reads this file automatically from the directory it runs
# in.

# --- Application ---
APP_NAME=Command Center
ENVIRONMENT=development          # development | production
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# --- PostgreSQL ---
POSTGRES_USER=commandcenter
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=commandcenter
